{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "CI=false ESLINT_NO_DEV_ERRORS=true npm run build",
  "env": {
    "CI": "false",
    "ESLINT_NO_DEV_ERRORS": "true",
    "DISABLE_ESLINT_PLUGIN": "true"
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
